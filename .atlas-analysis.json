  "publicApiSurface": [
    "kolibri start - Start the Kolibri server",
    "kolibri stop - Stop the Kolibri server",
    "kolibri plugin enable/disable - Manage plugins",
    "kolibri manage - Django management commands",
    "/api/auth/* - Authentication and user management endpoints",
    "/api/content/* - Content channel and metadata endpoints",
    "/api/lessons/* - Lesson management endpoints",
    "/api/exams/* - Quiz and exam endpoints",
    "/api/facility/* - Facility and user administration endpoints",
    "/api/device/* - Device configuration endpoints",
    "/api/logger/* - Learning analytics and logging endpoints",
    "KolibriPluginBase - Base class for plugin development",
    "ValuesViewset/ReadOnlyValuesViewset - API viewset patterns",
    "createTranslator() - Frontend i18n helper",
    "Resource class - Frontend API client",
    "Kolibri Design System components - KButton, KModal, KTextbox, etc."
  ]
